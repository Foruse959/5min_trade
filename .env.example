# ═══════════════════════════════════════════════════════════════════
# 5min_trade — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# TELEGRAM
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# POLYMARKET WALLET (required for live trading only)
POLY_PRIVATE_KEY=your_metamask_private_key
POLY_SAFE_ADDRESS=0xYourPolymarketSafeAddress
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# TRADING
TRADING_MODE=paper
STARTING_BALANCE=100.0
ENABLED_COINS=BTC,ETH,SOL
ENABLED_TIMEFRAMES=5,15

# RISK
MAX_DAILY_LOSS_PCT=15.0
MAX_TOTAL_POSITIONS=10
USE_KELLY_SIZING=true
KELLY_FRACTION=0.25

# STRATEGY TUNING
FLASH_DROP_THRESHOLD=0.25
ORACLE_PRICE_BUFFER=0.005
ARB_MAX_COMBINED_PRICE=0.98
